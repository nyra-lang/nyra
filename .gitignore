# =============================================================================
# Nyra — build artifacts, caches, and local-only files
# =============================================================================

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
target/
.nyra-test/
**/*.rs.bk
# -----------------------------------------------------------------------------
# Nyra compiler output (LLVM IR, linked binaries, wasm)
# -----------------------------------------------------------------------------
*.ll
*.wasm
*.exe
*.pdb

# Nyra package cache (downloaded deps from `nyra pkg install`)
.nyra/

# -----------------------------------------------------------------------------
# Native link artifacts
# -----------------------------------------------------------------------------
*.o
*.a
*.so
*.dylib
*.dll

# -----------------------------------------------------------------------------
# Fuzzing (cargo-fuzz)
# -----------------------------------------------------------------------------
fuzz/artifacts/
fuzz/corpus/*.lock

# -----------------------------------------------------------------------------
# Node.js (examples/ffi, etc.)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# OS-generated
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Logs, temp, and local scratch
# -----------------------------------------------------------------------------
*.log
tmp/
temp/
.cache/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Test & coverage reports
# -----------------------------------------------------------------------------
coverage/
*.profraw
*.profdata
tarpaulin-report.html
lcov.info

# -----------------------------------------------------------------------------
# Local dev / accidental dumps (do not commit)
# -----------------------------------------------------------------------------
root_git_status_sb.txt


ccomit.txt